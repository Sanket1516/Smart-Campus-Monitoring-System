# ──────────────────────────────────────────────
# Smart Campus Entry Monitor - Backend ENV
# ──────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/smart_campus

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email (Nodemailer - Amazon SES or Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Your Campus Name <noreply@yourcampus.edu>"

# SMS (Fast2SMS - India)
FAST2SMS_API_KEY=your_fast2sms_api_key

# Fingerprint Template Encryption (AES-256)
FP_SECRET=your_fingerprint_encryption_secret_key_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Enrollment Terminal IP (eSSL X990 in admin office)
ENROLLMENT_TERMINAL_IP=192.168.1.50

# ──────────────────────────────────────────────
# DEPRECATED - Now stored in SystemConfig
# ──────────────────────────────────────────────
# CURFEW_HOUR is now managed via Settings UI
# All notification toggles are in SystemConfig
# College branding is in SystemConfig
# ──────────────────────────────────────────────
